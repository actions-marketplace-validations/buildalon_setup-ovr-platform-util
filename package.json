{
  "name": "setup-ovr-platform-util",
  "version": "1.2.0",
  "description": "A GitHub Action to setup the ovr-platform-util tool command alias.",
  "author": "buildalon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/buildalon/setup-ovr-platform-util.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/buildalon/setup-ovr-platform-util/issues"
  },
  "homepage": "https://github.com/buildalon/setup-ovr-platform-util",
  "keywords": [
    "oculus",
    "ovr",
    "platform",
    "utility",
    "setup",
    "github",
    "action"
  ],
  "main": "dist/index.js",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/tool-cache": "^2.0.2",
    "semver": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/semver": "^7.7.1",
    "@vercel/ncc": "^0.34.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "npm run clean && npm run bundle",
    "bundle": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "clean": "npm install && shx rm -rf dist/ out/ node_modules/ && npm ci"
  },
  "overrides": {
    "@actions/http-client": "^3.0.2"
  }
}
